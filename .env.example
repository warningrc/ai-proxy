OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_key
# INFO | DEBUG (DEBUG prints each upstream SSE JSON chunk)
LOG_LEVEL=INFO

# 可选：模型别名映射。请求上游前，会把客户端传入的 model 替换为映射后的模型名；
# 未命中映射的模型名原样透传。
# 支持两种格式（任选一种）：
#   1) JSON 对象：MODEL_ALIASES={"claude-3-5-sonnet-20241022":"gpt-4o","claude-3-5-haiku-20241022":"gpt-4o-mini"}
#   2) 逗号分隔的键值对：MODEL_ALIASES=claude-3-5-sonnet-20241022=gpt-4o,claude-3-5-haiku-20241022=gpt-4o-mini
# MODEL_ALIASES=
